<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════════════════════════════════════
       OrpheusMP — Muse Layout Styles
       Control styles for the Muse layout.
       All color references use DynamicResource so palette
       variants and user overrides apply automatically.
       ═══════════════════════════════════════════════════════ -->

  <!-- ── Window ──────────────────────────────────────────── -->

  <Style Selector="Window">
    <Setter Property="FontFamily" Value="Fira Sans, Noto Sans, sans-serif" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
  </Style>

  <!-- ── Panels ──────────────────────────────────────────── -->

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{DynamicResource PanelFill}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelStroke}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="8" />
  </Style>

  <Style Selector="Border.panel.tight">
    <Setter Property="Padding" Value="6" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="10" />
  </Style>

  <Style Selector="Border.accent-bar">
    <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <Style Selector="Border.table-header">
    <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelStroke}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="6" />
  </Style>

  <!-- ── Typography ──────────────────────────────────────── -->

  <Style Selector="TextBlock.heading">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.subheading">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
  </Style>

  <Style Selector="TextBlock.small">
    <Setter Property="FontSize" Value="11" />
  </Style>

  <!-- ── Buttons ─────────────────────────────────────────── -->

  <Style Selector="Button">
    <Setter Property="Background" Value="{DynamicResource ButtonFill}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelStroke}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="10,6" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{DynamicResource ButtonHover}" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="{DynamicResource ButtonPressed}" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource AccentColor}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentText}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}" />
  </Style>

  <Style Selector="Button.icon">
    <Setter Property="Padding" Value="8" />
    <Setter Property="MinWidth" Value="36" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <!-- ── Transport icons ────────────────────────────────── -->
  <!--
    SVG icons are loaded via SvgIconHelper with fill/stroke colors
    set from the IconColor / IconActiveColor palette keys.
    The ViewModel provides pre-colored IImage instances to each
    Image.transport control.
  -->

  <Style Selector="Image.transport">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
  </Style>

  <Style Selector="Button.primary Image.transport">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
  </Style>

  <!-- ── Toggle Buttons ──────────────────────────────────── -->

  <Style Selector="ToggleButton">
    <Setter Property="Background" Value="{DynamicResource ButtonFill}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelStroke}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="10,6" />
  </Style>

  <Style Selector="ToggleButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource ButtonHover}" />
  </Style>

  <Style Selector="ToggleButton:checked">
    <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}" />
    <Setter Property="Foreground" Value="{DynamicResource AccentText}" />
  </Style>

  <Style Selector="ToggleButton.icon">
    <Setter Property="Padding" Value="8" />
    <Setter Property="MinWidth" Value="36" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <!-- SVG icon color for checked toggle buttons is handled via CSS on SvgImage resources -->

  <!-- ── ListBox ─────────────────────────────────────────── -->

  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Padding" Value="2,1" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ListBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource RowHover}" />
  </Style>

  <Style Selector="ListBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource RowSelected}" />
  </Style>

  <Style Selector="ListBoxItem.playing">
    <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}" />
    <Setter Property="BorderThickness" Value="2,0,0,0" />
  </Style>

  <!-- ── DataGrid ────────────────────────────────────────── -->

  <Style Selector="DataGrid">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="DataGridRow">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="DataGridRow:pointerover">
    <Setter Property="Background" Value="{DynamicResource RowHover}" />
  </Style>

  <Style Selector="DataGridRow:selected">
    <Setter Property="Background" Value="{DynamicResource RowSelected}" />
  </Style>

  <Style Selector="DataGridCell">
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="TextBlock.TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style Selector="DataGridCell TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
  </Style>

  <Style Selector="DataGridColumnHeader">
    <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelStroke}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
  </Style>

  <Style Selector="DataGridColumnHeader:pointerover">
    <Setter Property="Background" Value="{DynamicResource RowHover}" />
  </Style>

  <!-- TreeView / TreeViewItem styling is handled entirely by the
       custom ControlTheme in Muse.axaml — no style overrides needed. -->

  <!-- ── GridSplitter ──────────────────────────────────────── -->

  <Style Selector="GridSplitter">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="GridSplitter:pointerover">
    <Setter Property="Background" Value="{DynamicResource PanelStroke}" />
  </Style>

  <!-- ── Slider ──────────────────────────────────────────── -->

  <Style Selector="Slider">
    <Setter Property="Margin" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinHeight" Value="20" />
    <Setter Property="Foreground" Value="{DynamicResource AccentColor}" />
    <Setter Property="Background" Value="{DynamicResource PanelStroke}" />
  </Style>

  <!-- ── Ambient decorations ─────────────────────────────── -->

  <Style Selector="Ellipse.ambient-1">
    <Setter Property="Fill" Value="{DynamicResource AccentColor}" />
    <Setter Property="Opacity" Value="0.14" />
  </Style>

  <Style Selector="Ellipse.ambient-2">
    <Setter Property="Fill" Value="{DynamicResource AccentSoft}" />
    <Setter Property="Opacity" Value="0.26" />
  </Style>

  <Style Selector="Rectangle.ambient-sheen">
    <Setter Property="Fill" Value="{DynamicResource SheenBrush}" />
    <Setter Property="Opacity" Value="0.35" />
  </Style>

  <!-- ── Reveal animations ───────────────────────────────── -->

  <Style Selector="Border.reveal-1">
    <Style.Animations>
      <Animation Duration="0:0:0.45">
        <KeyFrame Cue="0%">
          <Setter Property="Opacity" Value="0" />
          <Setter Property="TranslateTransform.Y" Value="10" />
        </KeyFrame>
        <KeyFrame Cue="100%">
          <Setter Property="Opacity" Value="1" />
          <Setter Property="TranslateTransform.Y" Value="0" />
        </KeyFrame>
      </Animation>
    </Style.Animations>
  </Style>

  <Style Selector="Border.reveal-2">
    <Style.Animations>
      <Animation Duration="0:0:0.55" Delay="0:0:0.08">
        <KeyFrame Cue="0%">
          <Setter Property="Opacity" Value="0" />
          <Setter Property="TranslateTransform.Y" Value="12" />
        </KeyFrame>
        <KeyFrame Cue="100%">
          <Setter Property="Opacity" Value="1" />
          <Setter Property="TranslateTransform.Y" Value="0" />
        </KeyFrame>
      </Animation>
    </Style.Animations>
  </Style>

  <Style Selector="Border.reveal-3">
    <Style.Animations>
      <Animation Duration="0:0:0.6" Delay="0:0:0.16">
        <KeyFrame Cue="0%">
          <Setter Property="Opacity" Value="0" />
          <Setter Property="TranslateTransform.Y" Value="12" />
        </KeyFrame>
        <KeyFrame Cue="100%">
          <Setter Property="Opacity" Value="1" />
          <Setter Property="TranslateTransform.Y" Value="0" />
        </KeyFrame>
      </Animation>
    </Style.Animations>
  </Style>

</Styles>
