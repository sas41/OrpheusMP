<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════════════════════════════════════
       Muse — Berry color variant
       A warm berry / coral red palette for the Muse layout.
       Only redefines colors; layout and styles are inherited.
       ═══════════════════════════════════════════════════════ -->

  <Color x:Key="AccentColor">#E65B6C</Color>
  <Color x:Key="AccentSoft">#3A1E25</Color>
  <Color x:Key="PanelFill">#1D232B</Color>
  <Color x:Key="PanelStroke">#2A343F</Color>
  <Color x:Key="TextPrimary">#EDF1F4</Color>
  <Color x:Key="TextMuted">#A5B2BC</Color>
  <Color x:Key="RowHover">#26313B</Color>
  <Color x:Key="RowSelected">#3A1F24</Color>
  <Color x:Key="ButtonFill">#26303A</Color>
  <Color x:Key="ButtonHover">#323E4A</Color>
  <Color x:Key="ButtonPressed">#1C232B</Color>
  <Color x:Key="IconColor">#E65B6C</Color>
  <Color x:Key="IconActiveColor">#FFFFFF</Color>
  <x:String x:Key="IconCss">svg { color: #E65B6C !important; }</x:String>
  <x:String x:Key="IconActiveCss">svg { color: #FFFFFF !important; }</x:String>

  <LinearGradientBrush x:Key="AppSurfaceBrush" StartPoint="0%,0%" EndPoint="100%,100%">
    <GradientStop Color="#15171A" Offset="0" />
    <GradientStop Color="#1E242B" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="SheenBrush" StartPoint="0%,0%" EndPoint="100%,0%">
    <GradientStop Color="#3A1E25" Offset="0" />
    <GradientStop Color="Transparent" Offset="1" />
  </LinearGradientBrush>

</ResourceDictionary>
