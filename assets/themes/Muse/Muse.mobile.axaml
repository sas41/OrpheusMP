<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Orpheus.Android">

  <!--
    Muse — mobile palette + layout.
    Contains the color tokens, brushes, and MobileMainLayout DataTemplate.
    No references to desktop View types.
    Loaded by Orpheus.Android and Orpheus.iOS instead of the full Muse.axaml.
  -->

  <!-- ── Default palette ─────────────────────────────────── -->

  <Color x:Key="AccentColor">#D4A843</Color>
  <Color x:Key="AccentSoft">#2E2718</Color>
  <Color x:Key="AccentText">#FFFFFF</Color>
  <Color x:Key="PanelFill">#1E1E1E</Color>
  <Color x:Key="PanelStroke">#333333</Color>
  <Color x:Key="TextPrimary">#E8E4DD</Color>
  <Color x:Key="TextMuted">#9A9488</Color>
  <Color x:Key="RowHover">#2A2A2A</Color>
  <Color x:Key="RowSelected">#3A3122</Color>
  <Color x:Key="ButtonFill">#282828</Color>
  <Color x:Key="ButtonHover">#363636</Color>
  <Color x:Key="ButtonPressed">#1A1A1A</Color>
  <Color x:Key="IconColor">#D4A843</Color>
  <Color x:Key="IconActiveColor">#FFFFFF</Color>

  <!-- ── Icon CSS strings ───────────────────────────────── -->

  <x:String x:Key="IconCss">svg { color: #D4A843 !important; }</x:String>
  <x:String x:Key="IconActiveCss">svg { color: #FFFFFF !important; }</x:String>

  <!-- ── Fluent Slider overrides ────────────────────────── -->

  <SolidColorBrush x:Key="SliderThumbBackground"              Color="{DynamicResource AccentColor}" />
  <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver"   Color="{DynamicResource AccentColor}" />
  <SolidColorBrush x:Key="SliderThumbBackgroundPressed"       Color="{DynamicResource AccentColor}" />
  <SolidColorBrush x:Key="SliderThumbBackgroundDisabled"      Color="{DynamicResource TextMuted}" />
  <SolidColorBrush x:Key="SliderTrackValueFill"               Color="{DynamicResource AccentColor}" />
  <SolidColorBrush x:Key="SliderTrackValueFillPointerOver"    Color="{DynamicResource AccentColor}" />
  <SolidColorBrush x:Key="SliderTrackValueFillPressed"        Color="{DynamicResource AccentColor}" />
  <SolidColorBrush x:Key="SliderTrackValueFillDisabled"       Color="{DynamicResource TextMuted}" />
  <SolidColorBrush x:Key="SliderTrackFill"                    Color="{DynamicResource PanelStroke}" />
  <SolidColorBrush x:Key="SliderTrackFillPointerOver"         Color="{DynamicResource PanelStroke}" />
  <SolidColorBrush x:Key="SliderTrackFillPressed"             Color="{DynamicResource PanelStroke}" />

  <!-- ── Fluent ToggleButton overrides ───────────────────── -->

  <SolidColorBrush x:Key="ToggleButtonBackgroundChecked"              Color="{DynamicResource AccentSoft}" />
  <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver"   Color="{DynamicResource AccentSoft}" />
  <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed"       Color="{DynamicResource AccentSoft}" />
  <SolidColorBrush x:Key="ToggleButtonForegroundChecked"              Color="{DynamicResource AccentText}" />
  <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver"   Color="{DynamicResource AccentText}" />
  <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed"       Color="{DynamicResource AccentText}" />
  <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked"             Color="{DynamicResource AccentColor}" />
  <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPointerOver"  Color="{DynamicResource AccentColor}" />
  <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPressed"      Color="{DynamicResource AccentColor}" />

  <!-- ── Surface brushes ─────────────────────────────────── -->

  <LinearGradientBrush x:Key="AppSurfaceBrush" StartPoint="0%,0%" EndPoint="100%,100%">
    <GradientStop Color="#141414" Offset="0" />
    <GradientStop Color="#1C1C1C" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="SheenBrush" StartPoint="0%,0%" EndPoint="100%,0%">
    <GradientStop Color="#2E2718" Offset="0" />
    <GradientStop Color="Transparent" Offset="1" />
  </LinearGradientBrush>

  <!-- ── Mobile main layout ─────────────────────────────── -->
  <!--
    Two tabs: Library | Queue
    Persistent transport footer at the bottom with the track name above the seek bar.
    Tab switching is driven by IsLibraryTabActive / IsQueueTabActive.
    All button Click handlers are dispatched in MainView.axaml.cs.
  -->

  <DataTemplate x:Key="MobileMainLayout" x:DataType="local:MobileViewModel">
    <Grid RowDefinitions="Auto,*,Auto"
          Background="{DynamicResource AppSurfaceBrush}">

      <!-- ── Tab bar ────────────────────────────────────── -->
      <Border Grid.Row="0"
              Background="{DynamicResource PanelFill}"
              BorderBrush="{DynamicResource PanelStroke}"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,*,Auto" Height="48">

          <Button x:Name="LibraryTabButton"
                  Grid.Column="0"
                  Background="Transparent"
                  Padding="0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
              <TextBlock Text="Library"
                         FontSize="13"
                         FontWeight="{Binding IsLibraryTabActive,
                             Converter={x:Static local:BoolToFontWeightConverter.Instance}}"
                         Foreground="{Binding IsLibraryTabActive,
                             Converter={x:Static local:BoolToAccentBrushConverter.Instance}}"
                         HorizontalAlignment="Center" />
              <Border Height="2" CornerRadius="1" Width="36"
                      Background="{DynamicResource AccentColor}"
                      IsVisible="{Binding IsLibraryTabActive}" />
            </StackPanel>
          </Button>

          <Button x:Name="QueueTabButton"
                  Grid.Column="1"
                  Background="Transparent"
                  Padding="0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
              <TextBlock Text="Queue"
                         FontSize="13"
                         FontWeight="{Binding IsQueueTabActive,
                             Converter={x:Static local:BoolToFontWeightConverter.Instance}}"
                         Foreground="{Binding IsQueueTabActive,
                             Converter={x:Static local:BoolToAccentBrushConverter.Instance}}"
                         HorizontalAlignment="Center" />
              <Border Height="2" CornerRadius="1" Width="36"
                      Background="{DynamicResource AccentColor}"
                      IsVisible="{Binding IsQueueTabActive}" />
            </StackPanel>
          </Button>

          <!-- Settings gear button -->
          <Button x:Name="SettingsButton"
                  Grid.Column="2"
                  Background="Transparent"
                  Padding="14,0"
                  VerticalAlignment="Stretch">
            <Image Source="{Binding SettingsIcon}" Width="20" Height="20" />
          </Button>

        </Grid>
      </Border>

      <!-- ── Tab content ────────────────────────────────── -->

      <!-- Library tab -->
      <Grid Grid.Row="1"
            IsVisible="{Binding IsLibraryTabActive}"
            RowDefinitions="Auto,*">

        <!-- Library header: breadcrumb or root controls -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelFill}"
                BorderBrush="{DynamicResource PanelStroke}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto">

            <!-- Back button (drilled in) -->
            <Button x:Name="LibraryBackButton"
                    Grid.Column="0"
                    Background="Transparent"
                    Padding="6,4"
                    IsVisible="{Binding CanNavigateBack}"
                    VerticalAlignment="Center">
              <Image Source="{Binding BackIcon}" Width="18" Height="18" />
            </Button>

            <!-- Current folder / library name -->
            <TextBlock Grid.Column="1"
                       Text="{Binding CurrentFolderName}"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"
                       VerticalAlignment="Center"
                       Margin="4,0"
                       TextTrimming="CharacterEllipsis" />

            <!-- Scanning indicator (replaces Add button while busy) -->
            <TextBlock Grid.Column="2"
                       Text="Scanning…"
                       FontSize="11"
                       Foreground="{DynamicResource TextMuted}"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       IsVisible="{Binding IsScanning}" />

            <!-- Add folder button (root level only) -->
            <Button x:Name="AddFolderButton"
                    Grid.Column="3"
                    Background="Transparent"
                    Padding="6,4"
                    VerticalAlignment="Center"
                    IsVisible="{Binding CanNavigateBack,
                        Converter={x:Static local:BoolInverseConverter.Instance}}">
              <Image Source="{Binding AddFolderIcon}" Width="20" Height="20" />
            </Button>

          </Grid>
        </Border>

        <!-- Folder children + tracks -->
        <ScrollViewer Grid.Row="1">
          <StackPanel>

            <!-- Sub-folder and playlist nodes -->
            <ItemsControl ItemsSource="{Binding DisplayedNodes}"
                          IsVisible="{Binding DisplayedNodes.Count,
                              Converter={x:Static local:CountToBoolConverter.Instance}}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="local:LibraryNode">
                  <Border Background="Transparent"
                          BorderBrush="{DynamicResource PanelStroke}"
                          BorderThickness="0,0,0,1"
                          Padding="12,0">
                    <Grid ColumnDefinitions="*,Auto,Auto" Height="52">

                      <!-- Folder: drill in / Playlist: load into queue -->
                      <Button x:Name="FolderDrillButton"
                              Grid.Column="0"
                              Background="Transparent"
                              Padding="0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              IsVisible="{Binding IsFolder}">
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                          <TextBlock Text="{Binding Name}"
                                     FontSize="15"
                                     Foreground="{DynamicResource TextPrimary}"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding Meta}"
                                     FontSize="11"
                                     Foreground="{DynamicResource TextMuted}"
                                     IsVisible="{Binding Meta,
                                         Converter={x:Static local:StringToBoolConverter.Instance}}" />
                        </StackPanel>
                      </Button>

                      <!-- Playlist: name + format badge -->
                      <Button x:Name="PlaylistLoadButton"
                              Grid.Column="0"
                              Background="Transparent"
                              Padding="0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              IsVisible="{Binding IsPlaylist}">
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                          <TextBlock Text="{Binding Name}"
                                     FontSize="15"
                                     Foreground="{DynamicResource TextPrimary}"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding Meta}"
                                     FontSize="11"
                                     Foreground="{DynamicResource TextMuted}" />
                        </StackPanel>
                      </Button>

                      <!-- Play folder / playlist -->
                      <Button x:Name="FolderPlayButton"
                              Grid.Column="1"
                              Background="Transparent"
                              Padding="10,0"
                              VerticalAlignment="Center">
                        <TextBlock Text="▶" FontSize="14"
                                   Foreground="{DynamicResource AccentColor}" />
                      </Button>

                      <!-- Enqueue folder / playlist -->
                      <Button x:Name="FolderEnqueueButton"
                              Grid.Column="2"
                              Background="Transparent"
                              Padding="10,0"
                              VerticalAlignment="Center">
                        <TextBlock Text="+" FontSize="18"
                                   Foreground="{DynamicResource TextMuted}" />
                      </Button>

                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Tracks in current folder -->
            <ItemsControl ItemsSource="{Binding DisplayedTracks}"
                          IsVisible="{Binding DisplayedTracks.Count,
                              Converter={x:Static local:CountToBoolConverter.Instance}}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="local:TrackRow">
                  <Border Background="Transparent"
                          BorderBrush="{DynamicResource PanelStroke}"
                          BorderThickness="0,0,0,1"
                          Padding="12,0">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" Height="52">

                      <!-- Track number -->
                      <TextBlock Grid.Column="0"
                                 Text="{Binding TrackNumber}"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextMuted}"
                                 VerticalAlignment="Center"
                                 Width="24"
                                 TextAlignment="Right"
                                 Margin="0,0,10,0" />

                      <!-- Play track -->
                      <Button x:Name="TrackPlayButton"
                              Grid.Column="1"
                              Background="Transparent"
                              Padding="0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">
                        <StackPanel VerticalAlignment="Center" Spacing="1">
                          <TextBlock Text="{Binding Title}"
                                     FontSize="14"
                                     Foreground="{DynamicResource TextPrimary}"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding Artist}"
                                     FontSize="11"
                                     Foreground="{DynamicResource TextMuted}"
                                     TextTrimming="CharacterEllipsis"
                                     IsVisible="{Binding Artist,
                                         Converter={x:Static local:StringToBoolConverter.Instance}}" />
                        </StackPanel>
                      </Button>

                      <!-- Duration -->
                      <TextBlock Grid.Column="2"
                                 Text="{Binding Duration}"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextMuted}"
                                 VerticalAlignment="Center"
                                 Margin="8,0" />

                      <!-- Enqueue -->
                      <Button x:Name="TrackEnqueueButton"
                              Grid.Column="3"
                              Background="Transparent"
                              Padding="8,0"
                              VerticalAlignment="Center">
                        <TextBlock Text="+" FontSize="18"
                                   Foreground="{DynamicResource TextMuted}" />
                      </Button>

                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty state -->
            <StackPanel IsVisible="{Binding IsLibraryEmpty}"
                        HorizontalAlignment="Center"
                        Margin="24,48,24,24"
                        Spacing="10">
              <TextBlock Text="No music found"
                         FontSize="16"
                         Foreground="{DynamicResource TextMuted}"
                         HorizontalAlignment="Center" />
              <TextBlock Text="Tap + to add a music folder"
                         FontSize="13"
                         Foreground="{DynamicResource TextMuted}"
                         HorizontalAlignment="Center" />
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </Grid>

      <!-- Queue tab -->
      <Grid Grid.Row="1"
            IsVisible="{Binding IsQueueTabActive}"
            RowDefinitions="Auto,*">

        <!-- Queue header: track count · Save · Clear -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelFill}"
                BorderBrush="{DynamicResource PanelStroke}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
          <Grid ColumnDefinitions="*,Auto,Auto">
            <TextBlock Grid.Column="0"
                       Text="{Binding QueueSummary}"
                       FontSize="13"
                       Foreground="{DynamicResource TextMuted}"
                       VerticalAlignment="Center" />
            <Button x:Name="SaveQueueButton"
                    Grid.Column="1"
                    Background="Transparent"
                    Padding="10,6"
                    Margin="0,0,4,0"
                    IsVisible="{Binding Queue.Count,
                        Converter={x:Static local:CountToBoolConverter.Instance}}">
              <TextBlock Text="Save" FontSize="13"
                         Foreground="{DynamicResource AccentColor}" />
            </Button>
            <Button x:Name="ClearQueueButton"
                    Grid.Column="2"
                    Background="Transparent"
                    Padding="10,6"
                    IsVisible="{Binding Queue.Count,
                        Converter={x:Static local:CountToBoolConverter.Instance}}">
              <TextBlock Text="Clear" FontSize="13"
                         Foreground="{DynamicResource TextMuted}" />
            </Button>
          </Grid>
        </Border>

        <!-- Queue body: list + floating drag preview -->
        <Grid Grid.Row="1">

          <!--
            ListBox with VirtualizingStackPanel (the default) so only visible
            rows are materialised regardless of queue size — essential for fast
            initial render and smooth scrolling on large queues.

            The ItemContainerTheme strips the default ListBoxItem chrome so
            our own Border/Grid drives the layout without any double-padding.
          -->
          <ListBox x:Name="QueueList"
                   ItemsSource="{Binding Queue}"
                   Background="Transparent"
                   BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerTheme>
              <ControlTheme TargetType="ListBoxItem">
                <Setter Property="Padding"    Value="0" />
                <Setter Property="Margin"     Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Template">
                  <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Stretch" />
                  </ControlTemplate>
                </Setter>
              </ControlTheme>
            </ListBox.ItemContainerTheme>

            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="local:QueueItemViewModel">
                <!--
                  Row background: RowSelected when playing, transparent otherwise.
                  A left accent strip (2 px) reinforces the "now playing" state.
                -->
                <Border BorderBrush="{DynamicResource PanelStroke}"
                        BorderThickness="0,0,0,1"
                        Background="{Binding IsPlaying,
                            Converter={x:Static local:BoolToRowBrushConverter.Instance}}">
                  <Grid ColumnDefinitions="Auto,*,Auto" Height="56">

                    <!-- ── Drag handle (☰) + now-playing accent strip ── -->
                    <!--
                      Handle is on the LEFT, opposite the ✕, to avoid accidental
                      removals when reaching for the drag grip.
                      The accent strip overlays the left edge of the same column
                      so no extra column is needed.
                    -->
                    <Panel Grid.Column="0" Width="44">
                      <Border x:Name="QueueDragHandle"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeNorthSouth">
                        <TextBlock Text="⠿"
                                   FontSize="16"
                                   Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                      </Border>
                      <!-- 3 px accent pill on the far-left edge when playing -->
                      <Border Width="3"
                              HorizontalAlignment="Left"
                              CornerRadius="0,2,2,0"
                              Margin="0,8,0,8"
                              Background="{DynamicResource AccentColor}"
                              IsVisible="{Binding IsPlaying}"
                              IsHitTestVisible="False" />
                    </Panel>

                    <!-- ── Track text (tap = play) ───────────────── -->
                    <Button x:Name="QueueItemPlayButton"
                            Grid.Column="1"
                            Background="Transparent"
                            Padding="6,0,4,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                      <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding Primary}"
                                   FontSize="14"
                                   FontWeight="{Binding IsPlaying,
                                       Converter={x:Static local:BoolToFontWeightConverter.Instance}}"
                                   Foreground="{Binding IsPlaying,
                                       Converter={x:Static local:BoolToAccentBrushConverter.Instance}}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Secondary}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"
                                   TextTrimming="CharacterEllipsis"
                                   IsVisible="{Binding Secondary,
                                       Converter={x:Static local:StringToBoolConverter.Instance}}" />
                      </StackPanel>
                    </Button>

                    <!-- ── Remove (✕) ─────────────────────────────── -->
                    <Button x:Name="QueueItemRemoveButton"
                            Grid.Column="2"
                            Background="Transparent"
                            Padding="12,0"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center">
                      <TextBlock Text="✕" FontSize="12"
                                 Foreground="{DynamicResource TextMuted}" />
                    </Button>

                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!--
            Drag preview pill — floats above the list during a drag.
            IsHitTestVisible=False prevents it stealing any pointer events.
          -->
          <Canvas x:Name="QueueDragPreviewCanvas"
                  IsHitTestVisible="False"
                  IsVisible="False">
            <Border x:Name="QueueDragPreviewBorder"
                    Background="{DynamicResource PanelFill}"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,8"
                    Opacity="0.93">
              <TextBlock x:Name="QueueDragPreviewText"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimary}"
                         MaxWidth="300"
                         TextTrimming="CharacterEllipsis" />
            </Border>
          </Canvas>

        </Grid>
      </Grid>

      <!-- ── Transport footer ───────────────────────────── -->
      <Border Grid.Row="2"
              Background="{DynamicResource PanelFill}"
              BorderBrush="{DynamicResource PanelStroke}"
              BorderThickness="0,1,0,0"
              Padding="12,8,12,12">
        <StackPanel Spacing="4">

          <!-- Track name above seek bar -->
          <TextBlock Text="{Binding NowPlayingLabel}"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimary}"
                     TextTrimming="CharacterEllipsis"
                     HorizontalAlignment="Center"
                     IsVisible="{Binding IsActive}" />

          <!-- Seek bar with time labels -->
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Grid.Column="0"
                       Text="{Binding NowPlayingTime,
                           Converter={x:Static local:TimeStringSplitConverter.PositionInstance}}"
                       FontSize="10"
                       Foreground="{DynamicResource TextMuted}"
                       VerticalAlignment="Center" />
            <Slider x:Name="PositionSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="{Binding PlaybackDuration}"
                    Value="{Binding PlaybackPosition, Mode=TwoWay}"
                    Margin="6,0"
                    VerticalAlignment="Center" />
            <TextBlock Grid.Column="2"
                       Text="{Binding NowPlayingTime,
                           Converter={x:Static local:TimeStringSplitConverter.DurationInstance}}"
                       FontSize="10"
                       Foreground="{DynamicResource TextMuted}"
                       VerticalAlignment="Center" />
          </Grid>

          <!-- Transport controls -->
          <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto,*,Auto"
                HorizontalAlignment="Stretch">

            <!-- Shuffle -->
            <ToggleButton x:Name="ShuffleButton"
                          Grid.Column="0"
                          IsChecked="{Binding IsShuffleEnabled, Mode=OneWay}"
                          Background="Transparent"
                          Padding="6"
                          VerticalAlignment="Center">
              <Image Source="{Binding ShuffleIcon}" Width="20" Height="20" />
            </ToggleButton>

            <!-- Previous -->
            <Button x:Name="PreviousButton"
                    Grid.Column="2"
                    Background="Transparent"
                    Padding="8"
                    HorizontalAlignment="Center">
              <Image Source="{Binding PreviousIcon}" Width="24" Height="24" />
            </Button>

            <!-- Play / Pause -->
            <Button x:Name="PlayPauseButton"
                    Grid.Column="4"
                    Background="{DynamicResource AccentSoft}"
                    Padding="14"
                    CornerRadius="30"
                    HorizontalAlignment="Center">
              <Image Source="{Binding PlayPauseIcon}" Width="26" Height="26" />
            </Button>

            <!-- Next -->
            <Button x:Name="NextButton"
                    Grid.Column="6"
                    Background="Transparent"
                    Padding="8"
                    HorizontalAlignment="Center">
              <Image Source="{Binding NextIcon}" Width="24" Height="24" />
            </Button>

            <!-- Repeat -->
            <ToggleButton x:Name="RepeatButton"
                          Grid.Column="8"
                          IsChecked="{Binding RepeatModeIsActive, Mode=OneWay}"
                          Background="Transparent"
                          Padding="6"
                          VerticalAlignment="Center">
              <Image Source="{Binding RepeatIcon}" Width="20" Height="20" />
            </ToggleButton>

          </Grid>

        </StackPanel>
      </Border>

    </Grid>
  </DataTemplate>

</ResourceDictionary>
