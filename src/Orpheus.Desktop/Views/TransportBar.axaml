<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Orpheus.Desktop"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="52"
             x:Class="Orpheus.Desktop.Views.TransportBar"
             x:DataType="local:MainWindowViewModel">
  <Border Classes="panel tight reveal-3" Padding="6,4">
    <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
      <!-- Row 0: Now-playing text + time -->
      <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto">
        <!-- Transport + shuffle/repeat labels eat no row space; text is in this row -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="0,0,12,0">
          <TextBlock Text="{Binding NowPlayingPrimary}" Classes="subheading" TextTrimming="CharacterEllipsis" />
          <TextBlock Text="-" Classes="muted" VerticalAlignment="Center"
                     IsVisible="{Binding NowPlayingSecondary.Length}" />
          <TextBlock Text="{Binding NowPlayingSecondary}" Classes="muted" VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <TextBlock Grid.Column="3" Text="{Binding NowPlayingTime}" Classes="muted small"
                   VerticalAlignment="Center" />
      </Grid>

      <!-- Row 1: All controls on one line -->
      <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="6">
        <!-- Transport buttons -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
          <Button Click="OnStopClick" Classes="icon" Width="30" Height="30" MinWidth="30" MinHeight="30" Padding="6"
                  ToolTip.Tip="Stop">
            <Image Source="{Binding StopIcon}" Classes="transport" />
          </Button>
          <Button Click="OnPrevClick" Classes="icon" Width="30" Height="30" MinWidth="30" MinHeight="30" Padding="6"
                  ToolTip.Tip="Previous">
            <Image Source="{Binding PreviousIcon}" Classes="transport" />
          </Button>
          <Button Click="OnPlayClick" Classes="primary icon" Width="30" Height="30" MinWidth="30" MinHeight="30" Padding="6"
                  ToolTip.Tip="Play / Pause">
            <Image Source="{Binding PlayPauseIconPrimary}" Classes="transport" />
          </Button>
          <Button Click="OnNextClick" Classes="icon" Width="30" Height="30" MinWidth="30" MinHeight="30" Padding="6"
                  ToolTip.Tip="Next">
            <Image Source="{Binding NextIcon}" Classes="transport" />
          </Button>
          <ToggleButton Click="OnShuffleClick" Classes="icon" Width="30" Height="30" MinWidth="30" MinHeight="30" Padding="6"
                        IsChecked="{Binding IsShuffleEnabled, Mode=OneWay}"
                        ToolTip.Tip="Shuffle">
            <Image Source="{Binding ShuffleIcon}" Classes="transport" />
          </ToggleButton>
          <ToggleButton Click="OnRepeatClick" Classes="icon" Width="30" Height="30" MinWidth="30" MinHeight="30" Padding="6"
                        IsChecked="{Binding IsRepeatEnabled, Mode=OneWay}"
                        ToolTip.Tip="{Binding RepeatLabel}">
            <Image Source="{Binding RepeatIcon}" Classes="transport" />
          </ToggleButton>
        </StackPanel>

        <!-- Seek slider (takes remaining space) -->
        <Slider Grid.Column="2" x:Name="PositionSlider"
                Minimum="0" Maximum="{Binding PlaybackDuration}"
                Value="{Binding PlaybackPosition, Mode=TwoWay}"
                VerticalAlignment="Center"
                PointerWheelChanged="OnPositionWheel" />

        <!-- Volume icon (mute/unmute) -->
        <Button Grid.Column="3" Classes="icon" Width="24" Height="24" MinWidth="24" MinHeight="24" Padding="4"
                Click="OnVolumeIconClick" ToolTip.Tip="Mute / Unmute"
                VerticalAlignment="Center">
          <Image Source="{Binding VolumeIcon}" Width="14" Height="14" />
        </Button>

        <!-- Volume slider -->
        <Slider Grid.Column="4" x:Name="VolumeSlider"
                Minimum="0" Maximum="100"
                Value="{Binding Volume, Mode=TwoWay}" Width="100"
                VerticalAlignment="Center"
                PointerWheelChanged="OnVolumeWheel" />
      </Grid>
    </Grid>
  </Border>
</UserControl>
