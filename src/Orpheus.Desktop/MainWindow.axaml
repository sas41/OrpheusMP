<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Orpheus.Desktop"
        xmlns:views="clr-namespace:Orpheus.Desktop.Views"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="Orpheus.Desktop.MainWindow"
        Width="1200"
        Height="740"
        MinWidth="940"
        MinHeight="600"
        Background="Transparent"
        x:DataType="local:MainWindowViewModel"
        Title="OrpheusMP">
    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Fira Sans, Noto Sans, sans-serif" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>

        <Style Selector="Border#RootSurface">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        </Style>

        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{DynamicResource PanelFill}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelStroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style Selector="Border.panel.tight">
            <Setter Property="Padding" Value="10" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style Selector="TextBlock.heading">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.subheading">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>

        <Style Selector="TextBlock.small">
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style Selector="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonFill}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelStroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="{DynamicResource ButtonHover}" />
        </Style>

        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="{DynamicResource ButtonPressed}" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentColor}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}" />
        </Style>

        <Style Selector="Border.accent-bar">
            <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource RowHover}" />
        </Style>

        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="{DynamicResource RowSelected}" />
        </Style>

        <Style Selector="TreeViewItem">
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style Selector="TreeViewItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource RowHover}" />
        </Style>

        <Style Selector="TreeViewItem:selected">
            <Setter Property="Background" Value="{DynamicResource RowSelected}" />
        </Style>

        <Style Selector="Border.table-header">
            <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelStroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8" />
        </Style>

        <Style Selector="Slider">
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style Selector="Ellipse.ambient-1">
            <Setter Property="Fill" Value="{DynamicResource AccentColor}" />
            <Setter Property="Opacity" Value="0.14" />
        </Style>

        <Style Selector="Ellipse.ambient-2">
            <Setter Property="Fill" Value="{DynamicResource AccentSoft}" />
            <Setter Property="Opacity" Value="0.26" />
        </Style>

        <Style Selector="Rectangle.ambient-sheen">
            <Setter Property="Fill" Value="{DynamicResource SheenBrush}" />
            <Setter Property="Opacity" Value="0.35" />
        </Style>

        <Style Selector="Border.reveal-1">
            <Style.Animations>
                <Animation Duration="0:0:0.45">
                                <KeyFrame Cue="0%">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="TranslateTransform.Y" Value="10" />
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="Opacity" Value="1" />
                                    <Setter Property="TranslateTransform.Y" Value="0" />
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
        </Style>

        <Style Selector="Border.reveal-2">
            <Style.Animations>
                <Animation Duration="0:0:0.55" Delay="0:0:0.08">
                                <KeyFrame Cue="0%">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="TranslateTransform.Y" Value="12" />
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="Opacity" Value="1" />
                                    <Setter Property="TranslateTransform.Y" Value="0" />
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
        </Style>

        <Style Selector="Border.reveal-3">
            <Style.Animations>
                <Animation Duration="0:0:0.6" Delay="0:0:0.16">
                                <KeyFrame Cue="0%">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="TranslateTransform.Y" Value="12" />
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="Opacity" Value="1" />
                                    <Setter Property="TranslateTransform.Y" Value="0" />
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
        </Style>
    </Window.Styles>

    <Border Name="RootSurface" Padding="12">
        <Grid>
            <Canvas Name="AmbientLayer" IsHitTestVisible="False" Panel.ZIndex="0">
                <Ellipse Classes="ambient-1" Width="380" Height="380" Canvas.Left="-120" Canvas.Top="-140" />
                <Ellipse Classes="ambient-2" Width="460" Height="460" Canvas.Left="680" Canvas.Top="-160" />
                <Rectangle Classes="ambient-sheen" Width="260" Height="520" Canvas.Left="420" Canvas.Top="140" />
            </Canvas>

            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12" Panel.ZIndex="1">
                <views:HeaderBar />

                <Grid Grid.Row="1">
                    <Grid ColumnDefinitions="240,*,260" ColumnSpacing="12">
                        <views:LibraryPanel Grid.Column="0" />
                        <views:TrackListPanel Grid.Column="1" />
                        <views:QueuePanel Grid.Column="2" />
                    </Grid>

                </Grid>

                <views:TransportBar Grid.Row="2" />
            </Grid>
        </Grid>
    </Border>
</Window>
