<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Orpheus.Android"
             x:Class="Orpheus.Android.SettingsView"
             x:DataType="local:MobileSettingsViewModel"
             x:CompileBindings="False"
             Background="{DynamicResource AppSurfaceBrush}">

  <UserControl.Resources>
    <!--
      SettingsActionRow — a full-width tappable row button.
      Background matches the panel (ButtonFill) so it sits inside a card,
      with a dimmed pressed state so the tap is clearly visible.
    -->
    <ControlTheme x:Key="SettingsActionRow" TargetType="Button">
      <Setter Property="Background"              Value="{DynamicResource ButtonFill}" />
      <Setter Property="Foreground"              Value="{DynamicResource TextPrimary}" />
      <Setter Property="BorderThickness"         Value="0" />
      <Setter Property="HorizontalAlignment"     Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment"   Value="Center" />
      <Setter Property="Padding"                 Value="16,0" />
      <Setter Property="Height"                  Value="52" />
      <Setter Property="CornerRadius"            Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border x:Name="PART_Root"
                  Background="{TemplateBinding Background}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                              Padding="{TemplateBinding Padding}"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}" />
          </Border>
        </ControlTemplate>
      </Setter>
      <Style Selector="^:pressed /template/ Border#PART_Root">
        <Setter Property="Background" Value="{DynamicResource ButtonPressed}" />
      </Style>
      <Style Selector="^:disabled">
        <Setter Property="Opacity" Value="0.45" />
      </Style>
    </ControlTheme>
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,*">

    <!-- Header bar -->
    <Border Grid.Row="0"
            Background="{DynamicResource PanelFill}"
            BorderBrush="{DynamicResource PanelStroke}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*" Height="48">

        <!-- Back button -->
        <Button x:Name="SettingsBackButton"
                Grid.Column="0"
                Background="Transparent"
                Padding="12,0"
                VerticalAlignment="Stretch">
          <TextBlock Text="‹ Back"
                     FontSize="15"
                     Foreground="{DynamicResource AccentColor}"
                     VerticalAlignment="Center" />
        </Button>

        <TextBlock Grid.Column="1"
                   Text="Settings"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0"
                   HorizontalAlignment="Right" />
      </Grid>
    </Border>

    <!-- Settings body -->
    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="0">

        <!-- ── Library section ─────────────────────────────── -->
        <Border Padding="16,12,16,4">
          <TextBlock Text="LIBRARY"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMuted}"
                     LetterSpacing="1.5" />
        </Border>

        <!-- Music folders list with scan progress -->
        <Border Background="{DynamicResource PanelFill}"
                BorderBrush="{DynamicResource PanelStroke}"
                BorderThickness="0,1,0,1">
          <StackPanel>

            <ItemsControl ItemsSource="{Binding MusicFolders}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="local:MobileFolderScanStatus">
                  <Border BorderBrush="{DynamicResource PanelStroke}"
                          BorderThickness="0,0,0,1"
                          Padding="16,10">
                    <StackPanel Spacing="6">

                      <!-- Folder path -->
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Path}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <Button x:Name="SettingsRemoveFolderButton"
                                Grid.Column="1"
                                Background="Transparent"
                                Padding="12,4"
                                VerticalAlignment="Center">
                          <TextBlock Text="Remove"
                                     FontSize="13"
                                     Foreground="{DynamicResource AccentColor}" />
                        </Button>
                      </Grid>

                      <!-- Files scan progress -->
                      <Grid ColumnDefinitions="64,*,Auto" ColumnSpacing="6">
                        <TextBlock Grid.Column="0"
                                   Text="Files"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"
                                   VerticalAlignment="Center" />
                        <ProgressBar Grid.Column="1"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding FsScanProgress}"
                                     IsIndeterminate="{Binding FsScanIsIndeterminate}"
                                     Height="5"
                                     VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"
                                   VerticalAlignment="Center">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}/{1}">
                              <Binding Path="FsScanDone" />
                              <Binding Path="FsScanTotal" />
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                      </Grid>

                      <!-- Metadata scan progress -->
                      <Grid ColumnDefinitions="64,*,Auto" ColumnSpacing="6">
                        <TextBlock Grid.Column="0"
                                   Text="Metadata"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"
                                   VerticalAlignment="Center" />
                        <ProgressBar Grid.Column="1"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding MetaProgress}"
                                     IsIndeterminate="{Binding MetaIsIndeterminate}"
                                     Height="5"
                                     VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"
                                   VerticalAlignment="Center">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}/{1}">
                              <Binding Path="MetaDone" />
                              <Binding Path="MetaTotal" />
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                      </Grid>

                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty state when no folders -->
            <Border Padding="16,14"
                    IsVisible="{Binding HasNoFolders}">
              <TextBlock Text="No music folders added"
                         FontSize="13"
                         Foreground="{DynamicResource TextMuted}" />
            </Border>

            <!-- Add folder row -->
            <Border BorderBrush="{DynamicResource PanelStroke}"
                    BorderThickness="0,1,0,0">
              <Button x:Name="SettingsAddFolderButton"
                      Theme="{StaticResource SettingsActionRow}">
                <TextBlock Text="Add Music Folder…"
                           FontSize="14"
                           Foreground="{DynamicResource AccentColor}" />
              </Button>
            </Border>

          </StackPanel>
        </Border>

        <!-- Rescan / Reset buttons -->
        <Border Background="{DynamicResource PanelFill}"
                BorderBrush="{DynamicResource PanelStroke}"
                BorderThickness="0,0,0,1"
                Margin="0,16,0,0">
          <StackPanel>

            <Button x:Name="SettingsRescanButton"
                    Theme="{StaticResource SettingsActionRow}"
                    IsEnabled="{Binding IsScanning,
                        Converter={x:Static local:BoolInverseConverter.Instance}}">
              <TextBlock FontSize="14"
                         Foreground="{DynamicResource TextPrimary}">
                <TextBlock.Text>
                  <Binding Path="IsScanning"
                           Converter="{x:Static local:BoolToRescanLabelConverter.Instance}" />
                </TextBlock.Text>
              </TextBlock>
            </Button>

            <Border BorderBrush="{DynamicResource PanelStroke}"
                    BorderThickness="0,1,0,0">
              <Button x:Name="SettingsResetLibraryButton"
                      Theme="{StaticResource SettingsActionRow}">
                <TextBlock Text="Reset Library Database"
                           FontSize="14"
                           Foreground="#E05555" />
              </Button>
            </Border>

          </StackPanel>
        </Border>

        <!-- Status message -->
        <Border Padding="16,8"
                IsVisible="{Binding StatusMessage,
                    Converter={x:Static local:StringToBoolConverter.Instance}}">
          <TextBlock Text="{Binding StatusMessage}"
                     FontSize="12"
                     Foreground="{DynamicResource TextMuted}" />
        </Border>

        <!-- ── Appearance section ──────────────────────────── -->
        <Border Padding="16,20,16,4">
          <TextBlock Text="APPEARANCE"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMuted}"
                     LetterSpacing="1.5" />
        </Border>

        <Border Background="{DynamicResource PanelFill}"
                BorderBrush="{DynamicResource PanelStroke}"
                BorderThickness="0,1,0,1">
          <StackPanel>

            <!-- Track display mode -->
            <Border Padding="16,10"
                    BorderBrush="{DynamicResource PanelStroke}"
                    BorderThickness="0,0,0,1">
              <StackPanel Spacing="6">
                <TextBlock Text="Track Display"
                           FontSize="14"
                           Foreground="{DynamicResource TextPrimary}" />
                <ComboBox ItemsSource="{Binding DisplayModes}"
                          SelectedItem="{Binding SelectedDisplayMode}"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource ButtonFill}"
                          Foreground="{DynamicResource TextPrimary}" />
              </StackPanel>
            </Border>

            <!-- Color variant -->
            <Border Padding="16,10">
              <StackPanel Spacing="6">
                <TextBlock Text="Color Variant"
                           FontSize="14"
                           Foreground="{DynamicResource TextPrimary}" />
                <ComboBox ItemsSource="{Binding Variants}"
                          SelectedItem="{Binding SelectedVariant}"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource ButtonFill}"
                          Foreground="{DynamicResource TextPrimary}" />
              </StackPanel>
            </Border>

          </StackPanel>
        </Border>

        <!-- ── Licenses section ───────────────────────────── -->
        <Border Padding="16,12,16,4">
          <TextBlock Text="LICENSES"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMuted}"
                     LetterSpacing="1" />
        </Border>

        <Border Background="{DynamicResource PanelFill}"
                BorderBrush="{DynamicResource PanelStroke}"
                BorderThickness="0,1,0,1">
          <ItemsControl ItemsSource="{Binding Licenses}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="local:MobileLicenseEntry">
                <Border BorderBrush="{DynamicResource PanelStroke}"
                        BorderThickness="0,0,0,1">
                  <StackPanel>

                    <!-- License row header — tap to expand/collapse -->
                    <Button x:Name="LicenseToggleButton"
                            Background="Transparent"
                            Padding="16,0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch">
                      <Grid ColumnDefinitions="*,Auto" Height="48">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                          <TextBlock Text="{Binding DisplayName}"
                                     FontSize="14"
                                     Foreground="{DynamicResource TextPrimary}"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding Url}"
                                     FontSize="11"
                                     Foreground="{DynamicResource AccentColor}"
                                     TextTrimming="CharacterEllipsis"
                                     IsVisible="{Binding Url,
                                         Converter={x:Static local:StringToBoolConverter.Instance}}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding IsExpanded,
                                       Converter={x:Static local:BoolToChevronConverter.Instance}}"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                      </Grid>
                    </Button>

                    <!-- License full text — visible when expanded -->
                    <Border IsVisible="{Binding IsExpanded}"
                            Padding="16,8"
                            Background="{DynamicResource AppSurfaceBrush}">
                      <TextBlock Text="{Binding Text}"
                                 FontSize="11"
                                 Foreground="{DynamicResource TextMuted}"
                                 TextWrapping="Wrap"
                                 FontFamily="Monospace" />
                    </Border>

                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Border>

        <Border Padding="16,20,16,24"
                IsVisible="{Binding HasBuildString}">
          <StackPanel Spacing="4">
            <TextBlock Text="BUILD"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMuted}"
                       LetterSpacing="1" />
            <TextBlock Text="{Binding BuildString}"
                       FontSize="11"
                       Foreground="{DynamicResource TextMuted}"
                       FontFamily="Monospace"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

  </Grid>

</UserControl>
